    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^25.2.3",
    "@types/pdfmake": "^0.3.2",
    "@types/pg": "^8.16.0",
    "@types/pino": "^7.0.4",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
